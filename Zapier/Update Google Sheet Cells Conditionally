// Zapier Code Action
export async function updateSheet(inputData: { spreadsheetId: string; jobId: string }): Promise<{ result: string }> {
  const { spreadsheetId, jobId } = inputData;

  try {
    const trimmedJobId = String(jobId).trim();

    // 1) Find which sheet contains the Job ID (check 2026 first, then 2025)
    const sheets = ['2026', '2025'];
    let sheetName: string | null = null;
    let rowIndex = -1;

    for (const sheet of sheets) {
      try {
        const jobIdRange = encodeURIComponent(`${sheet}!A1:A10000`);
        const colARes = await fetchWithZapier(
          `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}/values/${jobIdRange}?majorDimension=COLUMNS`
        );
        await colARes.throwErrorIfNotOk();
        const colAData = await colARes.json();
        const colA: string[] = (colAData.values?.[0] ?? []).map((v: any) => String(v || '').trim());

        const foundIndex = colA.findIndex(v => v === trimmedJobId);
        if (foundIndex !== -1) {
          sheetName = sheet;
          rowIndex = foundIndex;
          break;
        }
      } catch (error) {
        // Continue to next sheet if this one fails
        continue;
      }
    }

    if (sheetName === null || rowIndex === -1) {
      throw new Error(`Job ID ${trimmedJobId} not found in column A of sheets "2026" or "2025".`);
    }
    const rowNumber = rowIndex + 1;

    // 2) Read F through J as unformatted numbers to avoid currency parsing
    const fjRange = encodeURIComponent(`${sheetName}!F${rowNumber}:J${rowNumber}`);
    const fjRes = await fetchWithZapier(
      `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}/values/${fjRange}?valueRenderOption=UNFORMATTED_VALUE`
    );
    await fjRes.throwErrorIfNotOk();
    const fjData = await fjRes.json();
    const rowValues: any[] = fjData.values?.[0] ?? [];

    const fValue = Number(rowValues[0] ?? 0);
    const jValue = Number(rowValues[4] ?? 0);

    const rValue = jValue >= fValue;

    // 3) Write S and T using USER_ENTERED so checkboxes and booleans are reliable
    const updateRange = encodeURIComponent(`${sheetName}!S${rowNumber}:T${rowNumber}`);
    const body = {
      range: `${sheetName}!S${rowNumber}:T${rowNumber}`,
      majorDimension: "ROWS",
      values: [[rValue ? "TRUE" : "FALSE", "TRUE"]]
    };

    const updateRes = await fetchWithZapier(
      `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}/values/${updateRange}?valueInputOption=USER_ENTERED&includeValuesInResponse=false`,
      {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body)
      }
    );
    await updateRes.throwErrorIfNotOk();

    return {
      result: `Row ${rowNumber} updated for Job ID ${trimmedJobId}. T set to TRUE, S set to ${rValue} based on J ${jValue} and F ${fValue}.`
    };
  } catch (error: any) {
    console.error("Error in updateSheet:", error);
    return { result: `Error: ${error.message ?? String(error)}` };
  }
}
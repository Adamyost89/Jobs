# Copy to `.env` for local development. Do not commit real secrets or `.env`.

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME"
JWT_SECRET="generate-a-long-random-string"
APP_BASE_URL="http://localhost:3000"

# SMTP for invite + forgot-password emails.
# For local testing you can use Mailtrap, SendGrid SMTP, etc.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Elevated Sheets <no-reply@example.com>"

# ProLine inbound webhook (optional). When set, POST /api/webhooks/proline requires:
#   Header `x-proline-signature: <same value>` OR `Authorization: Bearer <same value>`
# Match this in ProLine (if supported) or a proxy (e.g. Zapier). See docs/PROLINE_INTEGRATION.md.
# PROLINE_WEBHOOK_SECRET=

# Set to 1 to log each ProLine webhook (match path, job id) to stdout — useful on Docker.
# PROLINE_WEBHOOK_DEBUG=1

# Required for first-time project rename write-back:
# when we assign a job number, app POSTs to this Zapier catch hook so Zap updates ProLine project_name.
# ZAPIER_PROLINE_NAME_WEBHOOK_URL=

# Shared auth for zapier bridge + rename hook (optional but recommended).
# ZAPIER_BRIDGE_SECRET=
